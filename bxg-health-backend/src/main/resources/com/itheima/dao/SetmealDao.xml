<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.itheima.dao.SetmealDao">

    <insert id="add" parameterType="com.itheima.pojo.Setmeal" useGeneratedKeys="true" keyProperty="id">
        insert into t_setmeal(code, name, sex, helpCode, age, price, remark, attention, img)
        values (#{code}, #{name}, #{sex}, #{helpCode}, #{age}, #{price}, #{remark}, #{attention}, #{img})
    </insert>

    <insert id="setSetmealAndCheckGroup" parameterType="map">
        insert into t_setmeal_checkgroup(setmeal_id, checkgroup_id)
        values (#{setmealId}, #{checkgroupId})
    </insert>

    <select id="pageQuery" resultType="com.itheima.pojo.Setmeal">
        select * from t_setmeal
        <if test="value != null and value.length > 0">
            where code = #{value} or name = #{value} or helpCode = #{value}
        </if>
    </select>
    <select id="findById" resultType="com.itheima.pojo.Setmeal">
        select * from t_setmeal where id = #{id}
    </select>

    <update id="edit" parameterType="com.itheima.pojo.Setmeal" useGeneratedKeys="true" keyProperty="id">
        update t_setmeal
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="sex != null">
                sex = #{sex},
            </if>
            <if test="code != null">
                code = #{code},
            </if>
            <if test="helpCode != null">
                helpCode = #{helpCode},
            </if>
            <if test="age != null">
                age = #{age},
            </if>
            <if test="price != null">
                price = #{price},
            </if>
            <if test="attention != null">
                attention = #{attention},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
            <if test="img != null">
                img = #{img},
            </if>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteCheckGroupIdsBySetmealId" parameterType="int">
        delete from t_setmeal_checkgroup where setmeal_id = #{setmealId}
    </delete>

    <select id="findSetmealCount" resultType="java.util.Map">
        select s.name, count(o.id) value from t_order o,t_setmeal s where o.setmeal_id = s.id group by s.name
    </select>
</mapper>
