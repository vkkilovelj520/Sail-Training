<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.itheima.dao.MemberDao">

    <select id="findMemberCountByMouths" resultType="java.lang.Integer">
        select count(*) from t_member where regTime &lt;= #{fullDate}
    </select>

    <select id="findMemberTotalCount" resultType="java.lang.Integer">
        SELECT COUNT(id) FROM t_member
    </select>
    <select id="findMemberCountByDate" resultType="java.lang.Integer">
        SELECT COUNT(id) FROM t_member WHERE regTime = #{today}
    </select>
    <select id="findMemberCountAfterDate" resultType="java.lang.Integer">
        SELECT COUNT(id) FROM t_member WHERE regTime &gt;= #{firstDay4ThisMonth}
    </select>
</mapper>
